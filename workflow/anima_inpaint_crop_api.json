{
  "1": {
    "inputs": {"image": "source.png"},
    "class_type": "LoadImage",
    "_meta": {"title": "重绘原图"}
  },
  "2": {
    "inputs": {"image": "mask.png"},
    "class_type": "LoadImage",
    "_meta": {"title": "重绘遮罩"}
  },
  "3": {
    "inputs": {"image": ["2", 0], "channel": "red"},
    "class_type": "ImageToMask",
    "_meta": {"title": "白色区域重绘"}
  },
  "11": {
    "inputs": {"text": "redraw selected area", "clip": ["462", 1]},
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "重绘内容"}
  },
  "12": {
    "inputs": {
      "text": "lowres, worst quality, low quality, bad anatomy, text, watermark",
      "clip": ["462", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "重绘负面提示词"}
  },
  "15": {
    "inputs": {"vae_name": "qwen_image_vae.safetensors"},
    "class_type": "VAELoader",
    "_meta": {"title": "Anima VAE"}
  },
  "20": {
    "inputs": {"pixels": ["21", 1], "vae": ["15", 0]},
    "class_type": "VAEEncode",
    "_meta": {"title": "裁切图像编码"}
  },
  "21": {
    "inputs": {
      "image": ["1", 0],
      "mask": ["3", 0],
      "downscale_algorithm": "lanczos",
      "upscale_algorithm": "lanczos",
      "preresize": false,
      "preresize_mode": "ensure minimum resolution",
      "preresize_min_width": 1024,
      "preresize_min_height": 1024,
      "preresize_max_width": 4096,
      "preresize_max_height": 4096,
      "mask_fill_holes": true,
      "mask_expand_pixels": 8,
      "mask_invert": false,
      "mask_blend_pixels": 32,
      "mask_hipass_filter": 0.1,
      "extend_for_outpainting": false,
      "extend_up_factor": 1.0,
      "extend_down_factor": 1.0,
      "extend_left_factor": 1.0,
      "extend_right_factor": 1.0,
      "context_from_mask_extend_factor": 1.5,
      "output_resize_to_target_size": true,
      "output_target_width": 1024,
      "output_target_height": 1024,
      "output_padding": "32",
      "device_mode": "gpu (much faster)"
    },
    "class_type": "InpaintCropImproved",
    "_meta": {"title": "快速重绘裁切"}
  },
  "22": {
    "inputs": {"samples": ["20", 0], "mask": ["21", 2]},
    "class_type": "SetLatentNoiseMask",
    "_meta": {"title": "裁切区域噪声遮罩"}
  },
  "23": {
    "inputs": {
      "model": ["462", 0],
      "seed": 0,
      "steps": 12,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["11", 0],
      "negative": ["12", 0],
      "latent_image": ["22", 0],
      "denoise": 1.0,
      "LanPaint_NumSteps": 2,
      "LanPaint_PromptMode": "Image First",
      "LanPaint_Info": "LanPaint KSampler.",
      "Inpainting_mode": "🖼️ Image Inpainting"
    },
    "class_type": "LanPaint_KSampler",
    "_meta": {"title": "LanPaint Fast 快速重绘采样器"}
  },
  "24": {
    "inputs": {"samples": ["23", 0], "vae": ["15", 0]},
    "class_type": "VAEDecode",
    "_meta": {"title": "快速重绘解码"}
  },
  "25": {
    "inputs": {"stitcher": ["21", 0], "inpainted_image": ["24", 0]},
    "class_type": "InpaintStitchImproved",
    "_meta": {"title": "重绘拼回原图"}
  },
  "26": {
    "inputs": {
      "images": ["25", 0],
      "filename_prefix": "astrbot/anima_inpaint"
    },
    "class_type": "SaveImage",
    "_meta": {"title": "快速重绘输出"}
  },
  "44": {
    "inputs": {
      "unet_name": "miaomiaoHarem_anima8Step10.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Anima UNET"}
  },
  "45": {
    "inputs": {
      "clip_name": "qwen_3_06b_base.safetensors",
      "type": "qwen_image",
      "device": "default"
    },
    "class_type": "CLIPLoader",
    "_meta": {"title": "Anima CLIP"}
  },
  "462": {
    "inputs": {
      "text": "",
      "loras": {"__value__": []},
      "model": ["44", 0],
      "clip": ["45", 0]
    },
    "class_type": "Lora Loader (LoraManager)",
    "_meta": {"title": "1️⃣Lora堆（动态）"}
  }
